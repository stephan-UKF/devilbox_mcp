# Netzwerk
PORT=8787
MCP_BIND_HOST=127.0.0.1

# Devilbox auf dem Host
DEVILBOX_DIR=../devilbox_community

# Projektbasis im php-Container
DEVILBOX_PROJECTS_DIR=/shared/httpd

# Ausfuehrung
DEVILBOX_EXEC_TIMEOUT_MS=600000

# Die folgenden DB-Werte sind optionale MCP-Overrides.
# Wenn sie leer bleiben, liest der Server bevorzugt die passenden Defaults
# aus DEVILBOX_DIR/.env, z. B. Service-Namen und Root-Credentials.

# MariaDB / MySQL
# DEVILBOX_MARIADB_SERVICE=mariadb
# DEVILBOX_MARIADB_SERVICE_CANDIDATES=mariadb,mysql
# DEVILBOX_MARIADB_USER=root
# DEVILBOX_MARIADB_PASSWORD=
# DEVILBOX_MARIADB_DATABASE=

# PostgreSQL
# DEVILBOX_POSTGRES_SERVICE=pgsql
# DEVILBOX_POSTGRES_SERVICE_CANDIDATES=pgsql,postgres,postgresql
# DEVILBOX_POSTGRES_USER=postgres
# DEVILBOX_POSTGRES_PASSWORD=
# DEVILBOX_POSTGRES_DATABASE=postgres

# MCP-Auth
MCP_AUTH_TOKEN=replace_with_a_secure_token
